# ─── Server ───
HOST=0.0.0.0
PORT=7900

# ─── Database ───
DATABASE_URL=postgres://nexus:nexus@localhost:5432/nexus_gate
REDIS_URL=redis://localhost:6379

# ─── Security (MUST change in production) ───
JWT_SECRET=change-me-to-a-random-32-char-string!!
ENCRYPTION_KEY=change-me-to-a-random-32char-key

# ─── Logging ───
RUST_LOG=nexus_gate=info,tower_http=info

# ─── Upstream defaults ───
CLAUDE_API_URL=https://api.anthropic.com
GEMINI_API_URL=https://generativelanguage.googleapis.com
OPENAI_API_URL=https://api.openai.com

# ─── Optional proxy (per-account proxy takes precedence) ───
# GLOBAL_PROXY_URL=socks5://127.0.0.1:1080

# ─── Docker Compose 生产部署专用 ───
# PostgreSQL 密码（docker-compose.prod.yml 使用）
POSTGRES_PASSWORD=change-this-pg-password

# Redis 密码（推荐设置）
REDIS_PASSWORD=change-this-redis-password

# 你的域名（Caddy 自动 HTTPS 或 Cloudflare 代理）
# 留空则 Caddy 监听 :80 不启用 TLS
DOMAIN=gate.example.com
